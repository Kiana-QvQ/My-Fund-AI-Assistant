# Any OpenAI-compatible chat completion endpoint can be used.
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_MODEL=

# Optional fallback: app reads OPENAI_API_KEY from ~/.codex/auth.json at runtime.
# The key is never copied into this project or written to reports.
# AI_AUTH_FILE=~/.codex/auth.json

# Optional: local model example
# AI_BASE_URL=http://localhost:11434/v1
# AI_API_KEY=ollama
# AI_MODEL=llama3.2
