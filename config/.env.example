# Any OpenAI-compatible chat completion endpoint can be used.
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_MODEL=
AI_WIRE_API=responses
AI_PROVIDER=OpenAI

# Optional fallback: app reads OPENAI_API_KEY from ~/.codex/auth.json at runtime.
# The key is never copied into this project or written to reports.
# AI_AUTH_FILE=~/.codex/auth.json
# AI_CONFIG_FILE=~/.codex/config.toml
# AI_HTTPS_PROXY=http://127.0.0.1:7890

# Optional: local model example
# AI_BASE_URL=http://localhost:11434/v1
# AI_API_KEY=ollama
# AI_MODEL=llama3.2

# Trade alert email (never commit real values; use GitHub Secrets in CI)
# ALERT_EMAIL=your_masked_or_local_only_address@example.com
# SMTP_USER=your_smtp_login@example.com
# SMTP_PASS=your_smtp_auth_code_not_login_password
# SMTP_HOST=smtp.qq.com
# SMTP_PORT=465
# MAIL_FROM=
# MONTHLY_BUDGET=300
