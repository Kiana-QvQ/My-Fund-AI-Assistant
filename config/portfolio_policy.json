{
  "name": "保守进阶型指数定投组合",
  "base_currency": "CNY",
  "minimum_holding_years": 3,
  "target_allocation": {
    "511360": 0.51,
    "510300": 0.27,
    "510500": 0.11,
    "513500": 0.08,
    "159941": 0.03
  },
  "rules": {
    "rebalance_period": "annual",
    "rebalance_deviation": 0.05,
    "dca_tiers": [
      {"below": 40, "fraction": 3.0, "action": "triple"},
      {"below": 50, "fraction": 2.0, "action": "double"},
      {"below": 60, "fraction": 1.5, "action": "sesqui"},
      {"below": 70, "fraction": 1.0, "action": "buy"},
      {"below": 80, "fraction": 0.7, "action": "light"},
      {"below": 90, "fraction": 0.5, "action": "half"}
    ],
    "take_profit_percentile_at_or_above": 90,
    "qdii_premium_pause_above": 0.02,
    "qdii_premium_resume_below": 0.01,
    "note": "A股/美股共用十年定投：＜40%→300%、40%~50%→200%、50%~60%→150%、60%~70%→100%、70%~80%→70%、80%~90%→50%、≥90%停买。1年建仓见 bootstrap；邮件频率见 alerts。"
  },
  "alerts": {
    "max_emails_per_month": 1,
    "take_profit_bypasses_monthly_cap": true,
    "note": "定投提醒默认每月最多1封（CST自然月）。止盈（有持仓）可突破月上限。改为2可允许同月上午+晚间各一封。--force 仍受月上限约束除非同时为止盈突破。"
  },
  "bootstrap": {
    "enabled": true,
    "max_fraction_of_target": 0.30,
    "min_amount": 10,
    "deep_drawdown_observe_at_or_above": 0.25,
    "indexes": ["沪深300", "中证500", "标普500"],
    "exclude": ["纳斯达克100"],
    "by_index": {
      "沪深300": {
        "max_10y_percentile_below": 95,
        "tiers": [
          {
            "percentile_1y_at_or_below": 50,
            "fraction": 1.0,
            "drawdown_at_or_above": 0.05
          },
          {
            "percentile_1y_at_or_below": 70,
            "fraction": 0.5,
            "drawdown_at_or_above": 0.04
          },
          {
            "percentile_1y_at_or_below": 90,
            "fraction": 0.25,
            "drawdown_at_or_above": 0.03
          }
        ]
      },
      "中证500": {
        "max_10y_percentile_below": 95,
        "tiers": [
          {
            "percentile_1y_at_or_below": 55,
            "fraction": 1.0,
            "drawdown_at_or_above": 0.06
          },
          {
            "percentile_1y_at_or_below": 75,
            "fraction": 0.5,
            "drawdown_at_or_above": 0.05
          },
          {
            "percentile_1y_at_or_below": 90,
            "fraction": 0.25,
            "drawdown_at_or_above": 0.04
          }
        ]
      },
      "标普500": {
        "require_verified": true,
        "qdii_premium_at_or_below": 0.02,
        "tiers": [
          {
            "percentile_1y_at_or_below": 50,
            "fraction": 1.0,
            "drawdown_at_or_above": 0.05
          },
          {
            "percentile_1y_at_or_below": 70,
            "fraction": 0.5,
            "drawdown_at_or_above": 0.04
          },
          {
            "percentile_1y_at_or_below": 85,
            "fraction": 0.25,
            "drawdown_at_or_above": 0.03
          }
        ]
      }
    },
    "note": "1年建仓三档（与十年定投取较高者）：100%/50%/25%。建仓规则未改。"
  },
  "guardrails": {
    "paper_or_advice_only": true,
    "automatic_order_placement": false,
    "require_human_confirmation": true
  }
}
